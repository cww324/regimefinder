# Coinbase Advanced Trade (CDP) keys
COINBASE_KEY_NAME="organizations/ORG_ID/apiKeys/KEY_ID"
COINBASE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END EC PRIVATE KEY-----\n"

# Candles endpoint (Advanced Trade)
COINBASE_CANDLES_URL="https://api.coinbase.com/api/v3/brokerage/market/products/{product_id}/candles"

# Product and ingestion settings
COINBASE_PRODUCT_ID="BTC-USD"
CANDLE_GRANULARITY_SEC=300
CANDLE_SAFETY_LAG_SEC=15
DB_PATH="data/market.sqlite"

# Paper fill assumptions (bps)
HALF_SPREAD_BPS=5
SLIPPAGE_BPS=5
ALLOW_SHORTS=false
COOLDOWN_BARS=1
BREAKOUT_ATR_BUFFER=0.2
BREAKOUT_REQUIRES_CLOSE=false
ENTRY_ER_MIN=0.35
ER_NO_TRADE_BAND_LOW=
ER_NO_TRADE_BAND_HIGH=
SKIP_TOP_DECILE_RV=false
RV_QUANTILE_WINDOW=2000
FREEZE_ATR_AT_ENTRY=false
ENABLE_RETEST=false
RETEST_ATR_BAND=0.2
RETEST_MAX_BARS=6
REQUIRE_EMA_CONFIRM=false
EMA_FAST_PERIOD=20
EMA_SLOW_PERIOD=50
EMA_SLOPE_BARS=3
EMA_SLOPE_MIN=0.0
MR_ENABLE=false
MR_Z_ENTRY=1.5
MR_Z_EXIT=0.0
MR_DEV_WINDOW=48
MR_MAX_HOLD_BARS=10

# Risk sizing (for audit)
INITIAL_EQUITY=10000
RISK_PCT=0.005

# Optional Exchange (classic) keys (only if you use the Exchange API)
# COINBASE_API_KEY=""
# COINBASE_API_SECRET=""
# COINBASE_API_PASSPHRASE=""

# Postgres rc schema (Phase 2+)
RC_DB_DSN="postgresql://user:pass@localhost:5432/regime_crypto"
